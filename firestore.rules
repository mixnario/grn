rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: posts
    // Document ID: auto-generated
    // Fields:
    //   - author: string (required, 1-50 chars)
    //   - savedItem: string (required, 1-100 chars)
    //   - action: string (required, 1-100 chars)
    //   - message: string (optional, 0-500 chars)
    //   - imageUrl: string (optional, URL format)
    //   - memeText: string (optional, 0-100 chars)
    //   - characterComment: map { character: string, text: string } (required)
    //   - likes: number (required, >= 0)
    //   - reactions: map { clap: number, fire: number } (required)
    //   - createdAt: timestamp (required)
    //   - isSample: boolean (optional)
    //
    // ===============================================================

    function isValidUrl(url) {
      return url == null || (url is string && (url.matches("^https://.*") || url.matches("^http://.*") || url.matches("^blob:.*")));
    }

    function isValidPost(data) {
      return data.author is string && data.author.size() > 0 &&
             data.savedItem is string && data.savedItem.size() > 0 &&
             data.action is string && data.action.size() > 0 &&
             data.characterComment is map &&
             data.likes is number &&
             data.reactions is map &&
             data.createdAt is timestamp;
    }

    match /posts/{postId} {
      // Public access as requested by user
      allow read: if true;
      allow create: if isValidPost(request.resource.data);
      allow update: if true; // Allow all updates for public access
      allow delete: if true;
    }

    match /users/{userId} {
      allow read, write: if true;
    }
  }
}
